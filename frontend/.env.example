# Local dev — API on your machine or Docker
VITE_API_URL=http://localhost:8000
VITE_API_KEY=

# Local dev — call EC2 API directly (must include port 8000)
# VITE_API_URL=http://YOUR_EC2_IP:8000
# VITE_API_KEY=your-api-key-if-set-on-ec2

# Vercel — browser calls same-origin /api (see frontend/api/[...path].js)
# Set these in Vercel Project → Settings → Environment Variables:
#   VITE_API_URL=/api
#   VITE_API_KEY=your-api-key-if-set-on-ec2
#   BACKEND_URL=http://YOUR_EC2_IP:8000
